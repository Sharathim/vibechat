# VibeChat Environment Variables
# Copy this to .env and fill in your values

# ===== REQUIRED =====

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Frontend URL (your EC2 public IP or domain)
FRONTEND_URL=http://your-ec2-ip

# Firebase
FIREBASE_PROJECT_ID=vibechat-version-1

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=vibechat-media
AWS_REGION=us-east-1

# ===== OPTIONAL =====

# YouTube API (for search)
YOUTUBE_API_KEY=your-youtube-api-key

# Gmail for sending OTPs
MAIL_EMAIL=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Frontend build-time variables
VITE_API_URL=http://your-ec2-ip:5000
VITE_WS_URL=ws://your-ec2-ip:5000
